# 1. Adiciona todas as alterações e reconhece os arquivos deletados
git add .

# 2. Cria um ponto de salvamento com uma descrição do que foi feito
git commit -m "Adição da 2ª página do relatório geral, ajustes de layout e limpeza de arquivos"

# 3. Envia as alterações para o GitHub
git push origin main